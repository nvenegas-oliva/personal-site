---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';
import Writing from '../components/Writing.astro';
import Speaking from '../components/Speaking.astro';
import Contact from '../components/Contact.astro';
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <About />
    <Projects />
    <Writing />
    <Speaking />
    <Contact />
  </main>
  <footer class="border-t border-gray-200 dark:border-white/[0.06] py-8">
    <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <p class="text-sm text-gray-400 dark:text-neutral-500">
        &copy; {new Date().getFullYear()} Nicolás Venegas
      </p>
      <div class="flex gap-5 text-sm">
        <a
          href="https://github.com/Schuchhardt"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 dark:text-neutral-500 hover:text-teal-600 dark:hover:text-teal-400 transition-colors"
        >
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/nvenegas-oliva"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 dark:text-neutral-500 hover:text-teal-600 dark:hover:text-teal-400 transition-colors"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </footer>
</Layout>
