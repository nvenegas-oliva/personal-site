---
interface Props {
  title: string;
  description: string;
  problem: string;
  architecture: string;
  decisions: string;
  result: string;
  link?: string;
  status?: 'live' | 'coming';
}

const {
  title,
  description,
  problem,
  architecture,
  decisions,
  result,
  link,
  status = 'live',
} = Astro.props;
---

<div class="rounded-lg p-6 transition-colors bg-white border border-gray-200 hover:bg-gray-50 dark:bg-white/[0.03] dark:border-white/[0.08] dark:hover:bg-white/[0.06] dark:hover:border-white/[0.12]">
  <div class="flex items-center gap-3 mb-2">
    <h3 class="text-lg font-medium">{title}</h3>
    {status === 'coming' && (
      <span class="text-xs font-mono px-2 py-0.5 bg-gray-100 dark:bg-white/[0.06] text-gray-500 dark:text-neutral-500 rounded">
        coming soon
      </span>
    )}
  </div>

  <p class="text-sm text-gray-500 dark:text-neutral-400 mb-4">{description}</p>

  <div class="space-y-3 text-sm text-gray-600 dark:text-neutral-400">
    <div>
      <h4 class="font-mono text-xs text-gray-500 dark:text-neutral-500 uppercase tracking-wider mb-1">Problem</h4>
      <p>{problem}</p>
    </div>
    <div>
      <h4 class="font-mono text-xs text-gray-500 dark:text-neutral-500 uppercase tracking-wider mb-1">Architecture</h4>
      <p>{architecture}</p>
    </div>
    <div>
      <h4 class="font-mono text-xs text-gray-500 dark:text-neutral-500 uppercase tracking-wider mb-1">Result</h4>
      <p>{result}</p>
    </div>
  </div>

  {link && (
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 text-teal-600 dark:text-teal-400 hover:underline text-sm mt-4"
    >
      View on GitHub &rarr;
    </a>
  )}
</div>
