---
const navLinks = [
  { label: 'About', href: '#about' },
  { label: 'Projects', href: '#projects' },
  { label: 'Writing', href: '#writing' },
  { label: 'Speaking', href: '#speaking' },
  { label: 'Contact', href: '#contact' },
];
---

<nav
  class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-[#0a0a0a]/80 backdrop-blur-sm border-b border-gray-200 dark:border-white/[0.08]"
>
  <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="text-sm font-mono font-medium tracking-tight">NV</a>

    <!-- Desktop -->
    <div class="hidden md:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-mono text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/blog"
        class="text-sm font-mono text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
      >
        Blog
      </a>
      <button
        id="theme-toggle"
        class="p-1.5 text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
        aria-label="Toggle theme"
      >
        <svg class="w-4 h-4 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <svg class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu button -->
    <div class="flex items-center gap-3 md:hidden">
      <button
        id="theme-toggle-mobile"
        class="p-1.5 text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
        aria-label="Toggle theme"
      >
        <svg class="w-4 h-4 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <svg class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
      </button>
      <button
        id="mobile-menu-btn"
        class="p-1.5 text-gray-500 dark:text-neutral-400"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-gray-200 dark:border-white/[0.08] bg-white dark:bg-[#0a0a0a]"
  >
    <div class="px-6 py-4 flex flex-col gap-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-mono text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors mobile-nav-link"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/blog"
        class="text-sm font-mono text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
      >
        Blog
      </a>
    </div>
  </div>
</nav>

<script>
  function toggleTheme() {
    const html = document.documentElement;
    html.classList.toggle('dark');
    localStorage.setItem(
      'theme',
      html.classList.contains('dark') ? 'dark' : 'light'
    );
  }

  document
    .getElementById('theme-toggle')
    ?.addEventListener('click', toggleTheme);
  document
    .getElementById('theme-toggle-mobile')
    ?.addEventListener('click', toggleTheme);

  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>
