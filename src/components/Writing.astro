---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const plannedPosts = [
  {
    title: 'Designing AI Evaluation Frameworks for Regulated Industries',
    description:
      'How we built the eval framework that gates every AI capability at LATAM before production.',
  },
  {
    title: 'What Breaks When You Deploy AI Agents in an Airline',
    description:
      'Real failure modes from building and deploying LATAM Chat.',
  },
  {
    title: 'Scaling RAG to 779K Calls in Aviation: A Technical Post-Mortem',
    description:
      'Architecture deep dive into the Cosmos retrieval pipeline.',
  },
];
---

<section id="writing" class="py-24">
  <div class="max-w-3xl mx-auto px-6">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-medium tracking-tight">Writing</h2>
      {posts.length > 0 && (
        <a
          href="/blog"
          class="text-sm text-teal-600 dark:text-teal-400 hover:underline"
        >
          All posts &rarr;
        </a>
      )}
    </div>

    {posts.length > 0 ? (
      <div class="space-y-1">
        {posts.slice(0, 3).map((post) => (
          <a href={`/blog/${post.slug}`} class="block group">
            <article class="py-4 border-b border-gray-200 dark:border-white/[0.06]">
              <div class="flex items-baseline justify-between gap-4">
                <h3 class="font-medium group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors">
                  {post.data.title}
                </h3>
                <time
                  datetime={post.data.date.toISOString()}
                  class="text-sm font-mono text-gray-400 dark:text-neutral-500 shrink-0"
                >
                  {post.data.date.toLocaleDateString('en-US', {
                    month: 'short',
                    year: 'numeric',
                  })}
                </time>
              </div>
              <p class="text-sm text-gray-500 dark:text-neutral-400 mt-1">
                {post.data.description}
              </p>
            </article>
          </a>
        ))}
      </div>
    ) : (
      <div class="space-y-1">
        <p class="text-sm text-gray-500 dark:text-neutral-500 mb-6">
          Upcoming technical posts:
        </p>
        {plannedPosts.map((post) => (
          <article class="py-4 border-b border-gray-200 dark:border-white/[0.06]">
            <h3 class="font-medium text-gray-400 dark:text-neutral-500">
              {post.title}
            </h3>
            <p class="text-sm text-gray-400 dark:text-neutral-500 mt-1">
              {post.description}
            </p>
          </article>
        ))}
      </div>
    )}
  </div>
</section>
